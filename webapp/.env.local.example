# Firebase — copy from Firebase console → Project settings → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google OAuth Client ID — copy from Firebase console → Authentication → Sign-in method → Google → Web client ID
# Required for Google Drive backup. Same project as Firebase.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Backend API (Spring Boot)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
